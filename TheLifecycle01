<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cosmic Khoj - Scientific Simulation</title>
    <style>
        body {
            margin: 0;
            padding: 0;
            overflow: hidden;
            background-color: #000;
            color: #fff;
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
        }

        #canvas-container {
            width: 100vw;
            height: 100vh;
        }

        /* Scientific UI Overlay */
        #hud {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            padding: 40px;
            box-sizing: border-box;
            background: radial-gradient(circle at center, transparent 40%, rgba(0,0,0,0.4) 100%);
        }

        .header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
        }

        .title-block h1 {
            margin: 0;
            font-size: 1.2rem;
            letter-spacing: 4px;
            text-transform: uppercase;
            color: #00e5ff;
        }

        .stats-block {
            text-align: right;
            font-family: 'monospace';
            font-size: 0.8rem;
            color: rgba(255,255,255,0.6);
        }

        .narrative-container {
            max-width: 500px;
            margin: 0 auto;
            text-align: center;
            background: rgba(0,0,0,0.6);
            padding: 20px;
            border-radius: 4px;
            border-top: 1px solid rgba(0,229,255,0.3);
            backdrop-filter: blur(10px);
            transition: all 0.8s ease;
        }

        #chapter-title {
            color: #00e5ff;
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 3px;
            margin-bottom: 10px;
        }

        #explanation {
            font-size: 1rem;
            line-height: 1.6;
            font-weight: 300;
        }

        .controls {
            pointer-events: all;
            display: flex;
            gap: 20px;
            justify-content: center;
            margin-top: 20px;
        }

        button {
            background: transparent;
            border: 1px solid #00e5ff;
            color: #00e5ff;
            padding: 8px 16px;
            cursor: pointer;
            text-transform: uppercase;
            font-size: 0.7rem;
            letter-spacing: 1px;
            transition: all 0.3s;
        }

        button:hover {
            background: #00e5ff;
            color: #000;
        }

        .progress-bar {
            position: absolute;
            bottom: 0;
            left: 0;
            height: 2px;
            background: #00e5ff;
            width: 0%;
            transition: width 0.1s linear;
        }

        #loading-screen {
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background: #000;
            display: flex;
            justify-content: center;
            align-items: center;
            z-index: 1000;
            transition: opacity 1s ease;
        }
    </style>
</head>
<body>

    <div id="loading-screen">
        <div style="letter-spacing: 5px;">CALIBRATING UNIVERSE...</div>
    </div>

    <div id="hud">
        <div class="header">
            <div class="title-block">
                <h1>Cosmic Khoj</h1>
                <p style="font-size: 0.6rem; margin: 5px 0; opacity: 0.5;">A Scientific Visualization of Universal Expansion</p>
            </div>
            <div class="stats-block">
                <div id="time-display">T + 0.00s</div>
                <div id="temp-display">TEMP: 10^32 K</div>
                <div id="scale-display">SCALE: SINGULARITY</div>
            </div>
        </div>

        <div class="narrative-container" id="narration-box">
            <div id="chapter-title">Chapter 1: The Singularity</div>
            <div id="explanation">Everything that ever was, or will be, was once compressed into a point of infinite density.</div>
            <div class="controls">
                <button onclick="prevChapter()">Previous</button>
                <button onclick="nextChapter()">Next Epoch</button>
            </div>
        </div>
    </div>

    <div class="progress-bar" id="timeline-progress"></div>
    <div id="canvas-container"></div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>

    <script>
        let scene, camera, renderer, clock;
        let currentChapter = 0;
        let particleSystem;
        let targetParticleState; // Will be initialized as Float32Array
        
        const PARTICLE_COUNT = 25000;

        const CHAPTERS = [
            {
                title: "Chapter 1: The Singularity",
                text: "Before the Big Bang, space and time did not exist. The entire universe was a hot, dense singularity.",
                temp: "10^32 K",
                scale: "SINGULARITY",
                time: "0s",
                mode: 'cluster'
            },
            {
                title: "Chapter 2: Inflation",
                text: "In a fraction of a second, the universe expanded exponentially. Space itself grew faster than the speed of light.",
                temp: "10^27 K",
                scale: "SOLAR SYSTEM SIZE",
                time: "10^-32s",
                mode: 'expand'
            },
            {
                title: "Chapter 3: The Primordial Soup",
                text: "Quarks and gluons cooled enough to form protons and neutrons. The universe was an opaque plasma of ionized gas.",
                temp: "10^12 K",
                scale: "10 LIGHT YEARS",
                time: "1s",
                mode: 'chaos'
            },
            {
                title: "Chapter 4: Recombination",
                text: "Electrons finally bound to nuclei, creating neutral atoms. Light could finally travel freely—this is the Cosmic Microwave Background.",
                temp: "3000 K",
                scale: "10,000 LIGHT YEARS",
                time: "380,000y",
                mode: 'grid'
            },
            {
                title: "Chapter 5: Stellar Dawn",
                text: "Gravity pulled gas into clouds, igniting the first stars. The Dark Ages ended as the universe was re-ionized.",
                temp: "100 K",
                scale: "1M LIGHT YEARS",
                time: "200My",
                mode: 'stars'
            },
            {
                title: "Chapter 6: Large Scale Structure",
                text: "Today, galaxies cluster along invisible filaments of Dark Matter, forming a cosmic web of infinite complexity.",
                temp: "2.7 K",
                scale: "93B LIGHT YEARS",
                time: "13.8By",
                mode: 'web'
            }
        ];

        function init() {
            scene = new THREE.Scene();
            camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 10000);
            camera.position.z = 1000;

            renderer = new THREE.WebGLRenderer({ antialias: true });
            renderer.setSize(window.innerWidth, window.innerHeight);
            renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
            document.getElementById('canvas-container').appendChild(renderer.domElement);

            clock = new THREE.Clock();

            // Pre-allocate the target state array (x, y, z, r, g, b per particle)
            targetParticleState = new Float32Array(PARTICLE_COUNT * 6);

            // Create Particle System
            const geo = new THREE.BufferGeometry();
            const pos = new Float32Array(PARTICLE_COUNT * 3);
            const colors = new Float32Array(PARTICLE_COUNT * 3);

            // Initialize with zeros to avoid NaN
            for (let i = 0; i < PARTICLE_COUNT * 3; i++) {
                pos[i] = 0;
                colors[i] = 1;
            }

            geo.setAttribute('position', new THREE.BufferAttribute(pos, 3));
            geo.setAttribute('color', new THREE.BufferAttribute(colors, 3));

            const mat = new THREE.PointsMaterial({
                size: 2,
                vertexColors: true,
                transparent: true,
                opacity: 0.8,
                blending: THREE.AdditiveBlending
            });

            particleSystem = new THREE.Points(geo, mat);
            // Disable frustum culling to prevent computeBoundingSphere errors if points jump large distances
            particleSystem.frustumCulled = false; 
            scene.add(particleSystem);

            window.addEventListener('resize', onResize);
            
            // Critical: Calculate first chapter state before starting animation
            updateChapter();
            
            // Start the loop
            animate();

            setTimeout(() => {
                document.getElementById('loading-screen').style.opacity = '0';
                setTimeout(() => document.getElementById('loading-screen').remove(), 1000);
            }, 1000);
        }

        function updateChapter() {
            const ch = CHAPTERS[currentChapter];
            document.getElementById('chapter-title').innerText = ch.title;
            document.getElementById('explanation').innerText = ch.text;
            document.getElementById('temp-display').innerText = `TEMP: ${ch.temp}`;
            document.getElementById('scale-display').innerText = `SCALE: ${ch.scale}`;
            document.getElementById('time-display').innerText = `T + ${ch.time}`;
            
            document.getElementById('timeline-progress').style.width = `${((currentChapter + 1) / CHAPTERS.length) * 100}%`;

            // Update target positions in our flat array
            for (let i = 0; i < PARTICLE_COUNT; i++) {
                let x, y, z, r, g, b;

                if (ch.mode === 'cluster') {
                    x = (Math.random() - 0.5) * 10;
                    y = (Math.random() - 0.5) * 10;
                    z = (Math.random() - 0.5) * 10;
                    r = 1; g = 1; b = 1;
                } 
                else if (ch.mode === 'expand') {
                    const radius = 800;
                    const theta = Math.random() * Math.PI * 2;
                    const phi = Math.acos(Math.random() * 2 - 1);
                    x = radius * Math.sin(phi) * Math.cos(theta);
                    y = radius * Math.sin(phi) * Math.sin(theta);
                    z = radius * Math.cos(phi);
                    r = 1; g = 0.5; b = 0.2;
                }
                else if (ch.mode === 'chaos') {
                    x = (Math.random() - 0.5) * 2000;
                    y = (Math.random() - 0.5) * 2000;
                    z = (Math.random() - 0.5) * 2000;
                    r = 0.2; g = 0.6; b = 1.0;
                }
                else if (ch.mode === 'grid') {
                    x = (i % 50 - 25) * 40;
                    y = (Math.floor(i / 50) % 50 - 25) * 40;
                    z = (Math.floor(i / 2500) - 5) * 40;
                    r = 0.5; g = 0.5; b = 0.5;
                }
                else if (ch.mode === 'stars') {
                    const cluster = Math.floor(i / 500);
                    const cx = (cluster % 5 - 2) * 400;
                    const cy = (Math.floor(cluster / 5) - 2) * 400;
                    x = cx + (Math.random() - 0.5) * 100;
                    y = cy + (Math.random() - 0.5) * 100;
                    z = (Math.random() - 0.5) * 100;
                    r = 1; g = 1; b = 0.8;
                }
                else if (ch.mode === 'web') {
                    const t = i / 1000;
                    x = Math.sin(t * 10) * 800 + (Math.random() - 0.5) * 50;
                    y = Math.cos(t * 7) * 800 + (Math.random() - 0.5) * 50;
                    z = (t * 2000) - 1000;
                    r = 0.4; g = 0.1; b = 0.8;
                }

                targetParticleState[i * 6] = x;
                targetParticleState[i * 6 + 1] = y;
                targetParticleState[i * 6 + 2] = z;
                targetParticleState[i * 6 + 3] = r;
                targetParticleState[i * 6 + 4] = g;
                targetParticleState[i * 6 + 5] = b;
            }
        }

        function nextChapter() {
            if (currentChapter < CHAPTERS.length - 1) {
                currentChapter++;
                updateChapter();
            }
        }

        function prevChapter() {
            if (currentChapter > 0) {
                currentChapter--;
                updateChapter();
            }
        }

        function onResize() {
            camera.aspect = window.innerWidth / window.innerHeight;
            camera.updateProjectionMatrix();
            renderer.setSize(window.innerWidth, window.innerHeight);
        }

        function animate() {
            requestAnimationFrame(animate);
            render();
        }

        function render() {
            const time = clock.getElapsedTime();
            const positions = particleSystem.geometry.attributes.position.array;
            const colors = particleSystem.geometry.attributes.color.array;

            // Smoothly interpolate particles to target state
            for (let i = 0; i < PARTICLE_COUNT; i++) {
                // Pos interpolation
                positions[i*3] += (targetParticleState[i*6] - positions[i*3]) * 0.05;
                positions[i*3+1] += (targetParticleState[i*6+1] - positions[i*3+1]) * 0.05;
                positions[i*3+2] += (targetParticleState[i*6+2] - positions[i*3+2]) * 0.05;

                // Color interpolation
                colors[i*3] += (targetParticleState[i*6+3] - colors[i*3]) * 0.05;
                colors[i*3+1] += (targetParticleState[i*6+4] - colors[i*3+1]) * 0.05;
                colors[i*3+2] += (targetParticleState[i*6+5] - colors[i*3+2]) * 0.05;
            }

            particleSystem.geometry.attributes.position.needsUpdate = true;
            particleSystem.geometry.attributes.color.needsUpdate = true;
            
            particleSystem.rotation.y += 0.0005;
            
            camera.position.x = Math.sin(time * 0.1) * 300;
            camera.lookAt(0,0,0);

            renderer.render(scene, camera);
        }

        window.onload = init;
    </script>
</body>
</html>
